# ── API 配置 ──────────────────────────────────────────────
# API 提供商选择：siliconflow 或 anthropic
API_PROVIDER=siliconflow

# 硅基流动 API Key（使用 DeepSeek 等开源模型）
SILICONFLOW_API_KEY=sk-ghcuxoweahucmyexsacadskczysiygtlunpgxmrufoeekmqu

# Anthropic API Key（使用 Claude 模型）
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# ── 飞书应用凭证 ──────────────────────────────────────────────
# 在飞书开放平台创建应用后获取：https://open.feishu.cn/
FEISHU_APP_ID=cli_a965e800e1b81cca
FEISHU_APP_SECRET=sIQmpLApCJ0NfZSOzZaEFh5RIVkG5pNA
FEISHU_VERIFICATION_TOKEN=vPDvFDBH6ttEpdg0vAEdIg7KEt2g4JTn
FEISHU_ENCRYPT_KEY=

# 飞书服务器端口
PORT=8000

# ── LLM 配置 ──────────────────────────────────────────────
# 模型选择
# - 硅基流动支持：deepseek-v4-flash, deepseek-v4-pro, deepseek-r1, Qwen/Qwen2.5-72B-Instruct 等
# - Anthropic 支持：claude-opus-4-6, claude-sonnet-4-6, claude-haiku-4-5
LLM_MODEL=deepseek-v4-flash

# 最大重试次数（Coder ↔ Critic 循环）
MAX_ITERATIONS=3

# 是否启用 Adaptive Thinking（仅 Anthropic 支持，关闭可节省 30-50% token）
ENABLE_THINKING=false

# API 调用重试配置
MAX_RETRIES=3
RETRY_DELAY=1.0

# ── 数据库配置 ──────────────────────────────────────────────
# 是否使用真实数据库（true/false，false 则使用 Mock 数据）
USE_REAL_DB=false

# MySQL 连接信息（USE_REAL_DB=true 时生效）
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=123456
DB_NAME=data_analysis
